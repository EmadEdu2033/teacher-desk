{
  "name": "teacher-desk",
  "version": "1.0.0",
  "description": "Offline desktop productivity app for online teachers — sticky notes, tasks, and a private podium hidden from screen sharing.",
  "main": "main.js",
  "author": "Teacher Desk",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "preview": "node scripts/preview-server.js",
    "build:unpacked": "electron-builder --win --x64 --publish never",
    "build:installer": "node scripts/make-installer.js",
    "sign:exe": "node scripts/sign.js dist/win-unpacked/Teacher\\ Desk.exe",
    "sign:installer": "node scripts/sign.js dist/TeacherDeskSetup.exe",
    "cert:dev": "node scripts/generate-self-signed-cert.js",
    "build:win": "npm run build:unpacked && npm run sign:exe && npm run build:installer && npm run sign:installer",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3": "11.5.0"
  },
  "devDependencies": {
    "electron": "33.2.0",
    "electron-builder": "25.1.8"
  },
  "build": {
    "appId": "com.teacherdesk.app",
    "productName": "Teacher Desk",
    "copyright": "Copyright © 2026 Teacher Desk",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*",
      "package.json",
      "!**/*.map",
      "!**/.DS_Store"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "zip",
          "arch": ["x64"]
        }
      ],
      "artifactName": "TeacherDesk-Windows.${ext}",
      "signAndEditExecutable": false,
      "publisherName": "Teacher Desk",
      "certificateFile": "build/cert.pfx",
      "certificatePassword": "${env.WIN_CSC_KEY_PASSWORD}",
      "_signing_note": "This block is consumed by scripts/sign.js (Linux-friendly osslsigncode). electron-builder itself does not sign here because signAndEditExecutable=false (Wine crashes in the Replit sandbox). Set the actual password via the WIN_CSC_KEY_PASSWORD env var; never put the literal password in this file."
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Teacher Desk",
      "uninstallDisplayName": "Teacher Desk",
      "deleteAppDataOnUninstall": false
    }
  }
}
